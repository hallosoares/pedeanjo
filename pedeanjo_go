#!/usr/bin/env bash
# pedeanjo_go — UK100 ORB Pre-Open Institutional Filter
# Usage: pedeanjo_go [OPTIONS]
#
# Options (passed through to uk100_orb_filter.py):
#   --raw             Show raw data at the end (debug)
#   --json            Output JSON instead of formatted text
#   --history [N]     Show last N analysis entries (default: 10)
#
# Examples:
#   pedeanjo_go                  # Full pre-open analysis
#   pedeanjo_go --raw            # Analysis + raw data
#   pedeanjo_go --json           # Machine-readable JSON output
#   pedeanjo_go --history        # Last 10 analysis entries
#   pedeanjo_go --history 20     # Last 20 entries

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
VENV_DIR="${SCRIPT_DIR}/venv"
TOOL="${SCRIPT_DIR}/uk100_orb_filter.py"

if [[ ! -d "${VENV_DIR}" ]]; then
    echo "ERROR: Virtual environment not found at ${VENV_DIR}"
    echo "Run: python3 -m venv ${VENV_DIR} && ${VENV_DIR}/bin/pip install -r ${SCRIPT_DIR}/requirements.txt"
    exit 1
fi

if [[ ! -f "${TOOL}" ]]; then
    echo "ERROR: uk100_orb_filter.py not found at ${TOOL}"
    exit 1
fi

exec "${VENV_DIR}/bin/python" "${TOOL}" "$@"
